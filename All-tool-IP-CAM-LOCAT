        if 'X-Forwarded-For' in self.headers:
            return self.headers['X-Forwarded-For'].split(',')[0].strip()
        return self.client_address[0]

    def capture_info(self):
        ip = self.get_client_ip()
        ua = self.headers.get('User-Agent', 'N/A')
        info = {
            'timestamp': datetime.now().strftime('%Y-%m-%d %H:%M:%S'),
            'ip': ip, 'user_agent': ua
        }
        print(f"[👤] New visitor: {ip}")
        if REQUESTS_AVAILABLE:
            try:
                r = requests.get(f"http://ip-api.com/json/{ip}", timeout=5)
                if r.status_code == 200:
                    d = r.json()
                    if d.get('status') == 'success':
                        info['location'] = {
                            'city': d.get('city'), 'country': d.get('country'),
                            'lat': d.get('lat'), 'lon': d.get('lon'),
                            'isp': d.get('isp'),
                            'maps': f"https://www.google.com/maps?q={d.get('lat')},{d.get('lon')}"
                        }
                        print(f"[📍] {d.get('city')}, {d.get('country')}")
            except: pass
        captured_data.append(info)
        self.save_data()
        return info

    def save_data(self):
        fn = f"mjco_data_{datetime.now().strftime('%Y%m%d')}.json"
        with open(fn, 'w') as f:
            json.dump(captured_data, f, indent=2, default=str)

