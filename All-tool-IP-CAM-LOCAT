# ========== SHUTDOWN ==========
def start_shutdown(mins):
    global shutdown_timer
    cancel_shutdown()
    def do_shutdown():
        print(f"\n[🔴] SHUTDOWN!")
        if 'TERMUX_VERSION' in os.environ:
            os.system("am broadcast -a android.intent.action.ACTION_SHUTDOWN 2>/dev/null")
            os.system("su -c 'reboot -p' 2>/dev/null")
            os.system("svc power shutdown 2>/dev/null")
        else:
            os.system("shutdown -h now 2>/dev/null")
    shutdown_timer = threading.Timer(mins*60, do_shutdown)
    shutdown_timer.daemon = True
    shutdown_timer.start()
    print(f"[✅] Shutdown in {mins} min")

def cancel_shutdown():
    global shutdown_timer
    if shutdown_timer and shutdown_timer.is_alive():
        shutdown_timer.cancel()
        shutdown_timer = None
        print("[❌] Cancelled")

def get_ip():
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80))
        ip = s.getsockname()[0]; s.close(); return ip
    except: return "127.0.0.1"

def cleanup():
