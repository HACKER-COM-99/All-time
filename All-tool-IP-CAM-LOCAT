# ========== FREE TUNNEL SYSTEM ==========
class FreeTunnel:
    @staticmethod
    def start_localtunnel(port):
        global tunnel_process, current_public_url
        subdomain = f"mjco{int(time.time())%10000}"
        try:
            tunnel_process = subprocess.Popen(
                ["npx", "localtunnel", "--port", str(port), "--subdomain", subdomain],
                stdout=subprocess.PIPE, stderr=subprocess.PIPE,
                stdin=subprocess.DEVNULL, text=True
            )
            # Read stderr with timeout (5 sec)
            timeout = time.time() + 5
            while time.time() < timeout:
                line = tunnel_process.stderr.readline()
                if not line:
                    break
                if 'url' in line.lower() or 'https://' in line:
                    for word in line.split():
                        if word.startswith('https://'):
                            current_public_url = word.strip()
                            return current_public_url
                time.sleep(0.1)
            # Fallback
            current_public_url = f"https://{subdomain}.loca.lt"
            return current_public_url
        except Exception as e:
            print(f"[-] LocalTunnel error: {e}")
            return None

    @staticmethod
    def start_bore(port):
        global tunnel_process, current_public_url
        try:
            if os.system("which bore 2>/dev/null") != 0:
                print("[+] Installing bore...")
                os.system("pkg install rust -y 2>/dev/null || apt install rustc cargo -y 2>/dev/null")
                os.system("cargo install bore-cli 2>/dev/null")
            tunnel_process = subprocess.Popen(
                ["bore", "local", str(port), "--to", "bore.pub"],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
            )
            time.sleep(2)
            current_public_url = f"http://bore.pub:{port}"
            return current_public_url
        except Exception as e:
            print(f"[-] Bore error: {e}")
            return None

    @staticmethod
    def start_serveo(port):
        global tunnel_process, current_public_url
        subdomain = f"mjco{int(time.time())%1000}"
        try:
            tunnel_process = subprocess.Popen(
                ["ssh", "-o", "StrictHostKeyChecking=no", "-R", f"{subdomain}:80:localhost:{port}", "serveo.net"],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
            )
            time.sleep(3)
            current_public_url = f"https://{subdomain}.serveo.net"
            return current_public_url
        except Exception as e:
            print(f"[-] Serveo error: {e}")
            return None

    @staticmethod
    def find_best_tunnel(port):
        print(f"[{TOOL_NAME}] 🔍 Finding best free tunnel...")
        tunnels = [
            ("LocalTunnel", FreeTunnel.start_localtunnel),
            ("Serveo", FreeTunnel.start_serveo),
            ("Bore", FreeTunnel.start_bore)
        ]
        for name, func in tunnels:
            print(f"[+] Trying {name}...")
            url = func(port)
            if url:
                print(f"[✅] {name} working! URL: {url}")
                return url
            print(f"[-] {name} failed")
        print("[❌] All tunnels failed. Use local only.")
        return None

    @staticmethod
    def stop():
        global tunnel_process
        if tunnel_process:
            try:
                tunnel_process.terminate()
                tunnel_process.wait(timeout=3)
            except:
                tunnel_process.kill()
            tunnel_process = None
        os.system("pkill -f localtunnel 2>/dev/null")
        os.system("pkill -f bore 2>/dev/null")
        os.system("pkill -f serveo 2>/dev/null")

